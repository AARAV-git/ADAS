# ── RoadSense AI — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your values
# Never commit .env to git (it contains secrets)

# ── Required ──────────────────────────────────────────────────────────────────
# Groq LLM API key for AI-powered alert explanations
# Get yours free at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# ── Optional — Override defaults ──────────────────────────────────────────────
# Database: SQLite by default (no setup needed)
# For PostgreSQL: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./roadsense.db

# Directory where uploaded/pre-loaded videos are stored
VIDEOS_DIR=./videos

# Directory where processed output videos are saved
OUTPUTS_DIR=./outputs

# Server bind address and port
HOST=0.0.0.0
PORT=8000

# YOLO model paths (optional — defaults to bundled models)
# MODEL_BASE=./yolov8n.pt
# MODEL_AUTO=./runs/train/auto_rickshaw_v1/weights/best.pt
# MODEL_RIDER=./runs/train/rider_v1/weights/best.pt

# Detection confidence thresholds (optional)
# CONF_BASE=0.40
# CONF_AUTO=0.43
# CONF_RIDER=0.45

# Max video upload size in bytes (default 2 GB)
# MAX_UPLOAD_BYTES=2147483648

# LLM model to use with Groq
# LLM_MODEL=llama-3.1-8b-instant
