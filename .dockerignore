## RoadSense AI — Docker Ignore

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environment
venv/
env/
.venv/

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo

# Secrets — never copy into image
.env

# Large video files — mounted as volume
vedio/
videos/
*.mp4
*.avi
*.mov
*.mkv

# Model training artifacts (keep only weights)
runs/train/*/events.out*
runs/train/*/results.csv
runs/train/*/labels*
runs/train/*/confusion*
runs/train/*/train_batch*
runs/train/*/val_batch*
runs/detect/

# Output videos
outputs/
backend/outputs/

# Database (mounted as volume)
*.db
*.db-shm
*.db-wal

# Docs & misc
*.md
*.docx
*.txt
!requirements.txt
overview.docx
backend_str.py
rename_vedio.py

# Tests
test_*.py
*_test.py
